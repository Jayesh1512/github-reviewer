# Database (Neon or local Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/gitreview

# Redis (Upstash) — optional for local dev
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GitHub OAuth — see README "GitHub OAuth callback"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI (Google Gemini)
GEMINI_API_KEY=

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match the URL you open in the browser (scheme + host + port, no trailing slash).
# For LAN access use e.g. http://192.168.1.10:3000 — same value in GitHub OAuth callback.
NEXTAUTH_URL=http://localhost:3000

# Same origin as NEXTAUTH_URL when using the app from one place.
NEXT_PUBLIC_APP_URL=http://localhost:3000
